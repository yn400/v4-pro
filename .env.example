# ============================================================
# V4 Pro 配置文件 — 复制为 .env 并填入你的 API Key
# ============================================================

# --- LLM Provider 选择 ---
# 可选值: openai | zhipu | tongyi | anthropic
V4_LLM_PROVIDER=openai

# --- OpenAI 兼容接口（OpenAI / 中转站）---
V4_OPENAI_API_KEY=sk-your-key-here
V4_OPENAI_BASE_URL=https://api.openai.com/v1
V4_OPENAI_MODEL=gpt-4o

# --- 智谱 AI (GLM) — 也是 OpenAI 兼容接口 ---
# V4_LLM_PROVIDER=zhipu
# V4_ZHIPU_API_KEY=your-zhipu-key
# V4_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# V4_ZHIPU_MODEL=glm-4-plus

# --- 通义千问 (Qwen) — 也是 OpenAI 兼容接口 ---
# V4_LLM_PROVIDER=tongyi
# V4_TONGYI_API_KEY=your-dashscope-key
# V4_TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# V4_TONGYI_MODEL=qwen-max

# --- Anthropic Claude（需额外依赖 anthropic 库）---
# V4_LLM_PROVIDER=anthropic
# V4_ANTHROPIC_API_KEY=your-anthropic-key
# V4_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- 模型参数 ---
V4_TEMPERATURE=0.7
V4_MAX_TOKENS=4096

# --- 工作区路径（所有中间产物存放位置）---
V4_WORKSPACE=./v4_workspace

# --- 日志级别 ---
V4_LOG_LEVEL=INFO
